{
  "meta": {
    "theme": "morethan.dark",
    "extends": "base",
    "description": "Morethan brand dark theme with cool neutral slate surfaces and softened orange accents."
  },
  "color": {
    "bg": "#1E2329",
    "surface": "#242D38",
    "surface_elevated": "#29333E",
    "text_primary": "#EAF0F6",
    "text_secondary": "#C5D0DB",
    "text_muted": "#95A3B3",
    "border": "#323E4D",
    "border_subtle": "#2A3440",
    "primary": "#D08A5F",
    "primary_hover": "#DB976C",
    "primary_active": "#BD7850",
    "on_primary": "#FFF8F2",
    "warning": "#D8A57E",
    "on_warning": "#1E2329",
    "focus_ring": "#D08A5F80"
  },
  "typography": {
    "font_family": {
      "sans": "Inter, Manrope, SF Pro Display, system-ui, sans-serif"
    }
  },
  "radius": {
    "md": "8px",
    "lg": "16px"
  }
}
