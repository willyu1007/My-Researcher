generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PaperProject {
  id                   String                @id
  titleCardId          String                @map("topicId")
  title                String
  researchDirection    String
  status               String
  paperActiveSpFull    String?
  paperActiveSpPartial String?
  createdAt            DateTime              @db.Timestamptz(6)
  nodes                StageNode[]
  snapshots            Snapshot[]
  literatureLinks      PaperLiteratureLink[]
}

model StageNode {
  id              String       @id
  paperId         String
  stageId         String
  moduleId        String
  versionId       String
  parentVersionId String?
  parentNodeIds   String[]     @default([])
  runId           String
  laneId          String
  attemptId       String
  createdBy       String
  createdAt       DateTime     @db.Timestamptz(6)
  payloadRef      String
  nodeStatus      String
  valueJudgement  Json?
  paper           PaperProject @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([paperId, nodeStatus])
}

model Snapshot {
  id                     String       @id
  paperId                String
  snapshotType           String
  spineType              String?
  nodeRefs               String[]     @default([])
  claimSetHash           String
  problemScopeHash       String
  datasetProtocolHash    String
  evaluationProtocolHash String
  createdAt              DateTime     @db.Timestamptz(6)
  createdBy              String
  paper                  PaperProject @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([paperId, snapshotType])
}

model LiteratureRecord {
  id                       String                          @id
  title                    String
  abstractText             String?
  keyContentDigest         String?
  authors                  String[]                        @default([])
  year                     Int?
  doiNormalized            String?                         @unique
  arxivId                  String?                         @unique
  normalizedTitle          String
  titleAuthorsYearHash     String?                         @unique
  rightsClass              String
  tags                     String[]                        @default([])
  activeEmbeddingVersionId String?
  createdAt                DateTime                        @db.Timestamptz(6)
  updatedAt                DateTime                        @db.Timestamptz(6)
  sources                  LiteratureSource[]
  topicScopes              TopicLiteratureScope[]
  paperLinks               PaperLiteratureLink[]
  pipelineState            LiteraturePipelineState?
  pipelineStageStates      LiteraturePipelineStageState[]
  pipelineRuns             LiteraturePipelineRun[]
  pipelineArtifacts        LiteraturePipelineArtifact[]
  activeEmbeddingVersion   LiteratureEmbeddingVersion?     @relation("ActiveEmbeddingVersion", fields: [activeEmbeddingVersionId], references: [id], onDelete: SetNull)
  embeddingVersions        LiteratureEmbeddingVersion[]    @relation("LiteratureEmbeddingVersionOwner")
  embeddingChunks          LiteratureEmbeddingChunk[]
  embeddingTokenIndexes    LiteratureEmbeddingTokenIndex[]
  autoPullSuggestions      AutoPullSuggestion[]
  titleCardSelections      TitleCardEvidenceSelection[]

  @@index([normalizedTitle])
  @@index([activeEmbeddingVersionId])
}

model LiteratureSource {
  id           String           @id
  literatureId String
  provider     String
  sourceItemId String
  sourceUrl    String
  rawPayload   Json
  fetchedAt    DateTime         @db.Timestamptz(6)
  literature   LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([provider, sourceItemId])
  @@index([literatureId])
}

model TopicLiteratureScope {
  id           String           @id
  topicId      String
  literatureId String
  scopeStatus  String
  reason       String?
  createdAt    DateTime         @db.Timestamptz(6)
  updatedAt    DateTime         @db.Timestamptz(6)
  literature   LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([topicId, literatureId])
  @@index([topicId])
}

model PaperLiteratureLink {
  id             String           @id
  paperId        String
  topicId        String?
  literatureId   String
  citationStatus String
  note           String?
  createdAt      DateTime         @db.Timestamptz(6)
  updatedAt      DateTime         @db.Timestamptz(6)
  paper          PaperProject     @relation(fields: [paperId], references: [id], onDelete: Cascade)
  literature     LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([paperId, literatureId])
  @@index([paperId])
  @@index([literatureId])
}

model LiteraturePipelineState {
  id               String           @id
  literatureId     String           @unique
  citationComplete Boolean          @default(false)
  abstractReady    Boolean          @default(false)
  keyContentReady  Boolean          @default(false)
  dedupStatus      String           @default("unknown")
  updatedAt        DateTime         @db.Timestamptz(6)
  literature       LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)
}

model LiteraturePipelineRun {
  id              String                         @id
  literatureId    String
  triggerSource   String
  status          String
  requestedStages String[]                       @default([])
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime                       @db.Timestamptz(6)
  startedAt       DateTime?                      @db.Timestamptz(6)
  finishedAt      DateTime?                      @db.Timestamptz(6)
  updatedAt       DateTime                       @db.Timestamptz(6)
  literature      LiteratureRecord               @relation(fields: [literatureId], references: [id], onDelete: Cascade)
  steps           LiteraturePipelineRunStep[]
  stageStates     LiteraturePipelineStageState[]

  @@index([literatureId, createdAt])
  @@index([literatureId, status])
  @@index([status])
}

model LiteraturePipelineStageState {
  id           String                 @id
  literatureId String
  stageCode    String
  status       String
  lastRunId    String?
  detail       Json
  updatedAt    DateTime               @db.Timestamptz(6)
  literature   LiteratureRecord       @relation(fields: [literatureId], references: [id], onDelete: Cascade)
  lastRun      LiteraturePipelineRun? @relation(fields: [lastRunId], references: [id], onDelete: SetNull)

  @@unique([literatureId, stageCode])
  @@index([stageCode, status])
  @@index([lastRunId])
}

model LiteraturePipelineRunStep {
  id           String                @id
  runId        String
  stageCode    String
  status       String
  inputRef     Json
  outputRef    Json
  errorCode    String?
  errorMessage String?
  startedAt    DateTime?             @db.Timestamptz(6)
  finishedAt   DateTime?             @db.Timestamptz(6)
  run          LiteraturePipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([stageCode, status])
}

model LiteraturePipelineArtifact {
  id           String           @id
  literatureId String
  stageCode    String
  artifactType String
  payload      Json
  checksum     String?
  createdAt    DateTime         @db.Timestamptz(6)
  updatedAt    DateTime         @db.Timestamptz(6)
  literature   LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([literatureId, stageCode, artifactType])
  @@index([literatureId, stageCode])
  @@index([stageCode, artifactType])
}

model LiteratureEmbeddingVersion {
  id           String                          @id
  literatureId String
  versionNo    Int
  provider     String
  model        String
  dimension    Int
  chunkCount   Int
  vectorCount  Int
  tokenCount   Int
  createdAt    DateTime                        @db.Timestamptz(6)
  updatedAt    DateTime                        @db.Timestamptz(6)
  literature   LiteratureRecord                @relation("LiteratureEmbeddingVersionOwner", fields: [literatureId], references: [id], onDelete: Cascade)
  activeFor    LiteratureRecord[]              @relation("ActiveEmbeddingVersion")
  chunks       LiteratureEmbeddingChunk[]
  tokenIndexes LiteratureEmbeddingTokenIndex[]

  @@unique([literatureId, versionNo])
  @@index([literatureId, createdAt])
  @@index([provider, model, dimension])
}

model LiteratureEmbeddingChunk {
  id                 String                     @id
  embeddingVersionId String
  literatureId       String
  chunkId            String
  chunkIndex         Int
  text               String
  startOffset        Int
  endOffset          Int
  vector             Json
  createdAt          DateTime                   @db.Timestamptz(6)
  updatedAt          DateTime                   @db.Timestamptz(6)
  embeddingVersion   LiteratureEmbeddingVersion @relation(fields: [embeddingVersionId], references: [id], onDelete: Cascade)
  literature         LiteratureRecord           @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([embeddingVersionId, chunkId])
  @@index([embeddingVersionId, chunkIndex])
  @@index([literatureId, chunkId])
}

model LiteratureEmbeddingTokenIndex {
  id                 String                     @id
  embeddingVersionId String
  literatureId       String
  token              String
  chunkIds           String[]                   @default([])
  createdAt          DateTime                   @db.Timestamptz(6)
  updatedAt          DateTime                   @db.Timestamptz(6)
  embeddingVersion   LiteratureEmbeddingVersion @relation(fields: [embeddingVersionId], references: [id], onDelete: Cascade)
  literature         LiteratureRecord           @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@unique([embeddingVersionId, token])
  @@index([literatureId, token])
}

model ApplicationSetting {
  id          String   @id
  namespace   String
  key         String
  value       Json
  secretValue String?
  createdAt   DateTime @db.Timestamptz(6)
  updatedAt   DateTime @db.Timestamptz(6)

  @@unique([namespace, key])
  @@index([namespace])
}

model TopicProfile {
  id                  String               @id
  name                String
  isActive            Boolean              @default(true)
  initialPullPending  Boolean              @default(false)
  includeKeywords     String[]             @default([])
  excludeKeywords     String[]             @default([])
  venueFilters        String[]             @default([])
  defaultLookbackDays Int                  @default(30)
  defaultMinYear      Int?
  defaultMaxYear      Int?
  createdAt           DateTime             @db.Timestamptz(6)
  updatedAt           DateTime             @db.Timestamptz(6)
  ruleLinks           AutoPullRuleTopic[]
  suggestions         AutoPullSuggestion[]
}

model AutoPullRule {
  id          String                 @id
  scope       String
  name        String
  status      String
  querySpec   Json
  timeSpec    Json
  qualitySpec Json
  createdAt   DateTime               @db.Timestamptz(6)
  updatedAt   DateTime               @db.Timestamptz(6)
  topics      AutoPullRuleTopic[]
  sources     AutoPullRuleSource[]
  schedules   AutoPullRuleSchedule[]
  runs        AutoPullRun[]
  cursors     AutoPullCursor[]
  alerts      AutoPullAlert[]

  @@index([scope, status])
}

model AutoPullRuleTopic {
  id        String       @id
  ruleId    String
  topicId   String
  createdAt DateTime     @db.Timestamptz(6)
  rule      AutoPullRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  topic     TopicProfile @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([ruleId, topicId])
  @@index([topicId])
  @@index([ruleId])
}

model AutoPullRuleSource {
  id       String       @id
  ruleId   String
  source   String
  enabled  Boolean      @default(true)
  priority Int          @default(100)
  config   Json
  rule     AutoPullRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, source])
  @@index([ruleId])
}

model AutoPullRuleSchedule {
  id         String       @id
  ruleId     String
  frequency  String
  daysOfWeek String[]     @default([])
  hour       Int
  minute     Int
  timezone   String
  active     Boolean      @default(true)
  rule       AutoPullRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutoPullRun {
  id             String                     @id
  ruleId         String
  triggerType    String
  status         String
  startedAt      DateTime?                  @db.Timestamptz(6)
  finishedAt     DateTime?                  @db.Timestamptz(6)
  summary        Json
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime                   @db.Timestamptz(6)
  updatedAt      DateTime                   @db.Timestamptz(6)
  rule           AutoPullRule               @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  sourceAttempts AutoPullRunSourceAttempt[]
  alerts         AutoPullAlert[]
  suggestions    AutoPullSuggestion[]

  @@index([ruleId, status])
  @@index([createdAt])
}

model AutoPullRunSourceAttempt {
  id            String      @id
  runId         String
  source        String
  status        String
  fetchedCount  Int
  importedCount Int
  failedCount   Int
  errorCode     String?
  errorMessage  String?
  startedAt     DateTime?   @db.Timestamptz(6)
  finishedAt    DateTime?   @db.Timestamptz(6)
  meta          Json
  run           AutoPullRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, source])
}

model AutoPullCursor {
  id          String       @id
  ruleId      String
  source      String
  cursorValue String
  cursorAt    DateTime     @db.Timestamptz(6)
  rule        AutoPullRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, source])
}

model AutoPullAlert {
  id        String       @id
  ruleId    String
  runId     String?
  source    String?
  level     String
  code      String
  message   String
  detail    Json
  ackAt     DateTime?    @db.Timestamptz(6)
  createdAt DateTime     @db.Timestamptz(6)
  rule      AutoPullRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  run       AutoPullRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([ruleId, createdAt])
  @@index([level, ackAt])
}

model AutoPullSuggestion {
  id             String           @id
  runId          String
  literatureId   String
  topicId        String?
  suggestedScope String
  reason         String
  score          Float
  createdAt      DateTime         @db.Timestamptz(6)
  run            AutoPullRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  literature     LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)
  topic          TopicProfile?    @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([topicId, suggestedScope])
}

// ---------------------------------------------------------------------------
// Title-card management mapped onto legacy Topic* physical tables. The Prisma
// client exposes title-card semantics while @map/@@map preserve DB compatibility.
// ---------------------------------------------------------------------------
enum TitleCardResearchRecordType {
  evidence_review
  need_review
  research_question  @map("question")
  value_assessment
  package            @map("topic_package")
  promotion_decision

  @@map("TopicResearchRecordType")
}

enum TitleCardStatus {
  draft
  active
  promoted
  parked
}

enum TitleCardResearchRecordStatus {
  draft
  completed
  superseded
  archived

  @@map("TopicResearchRecordStatus")
}

enum TitleCardValueVerdict {
  promote
  refine
  park
  drop

  @@map("TopicValueVerdict")
}

enum TitleCardPromotionDecisionType {
  promote
  hold
  reject
  loopback

  @@map("TopicPromotionDecisionType")
}

enum TitleCardContributionHypothesis {
  method
  benchmark
  analysis
  resource
  system

  @@map("TopicContributionHypothesis")
}

model TitleCardResearchRecord {
  id                   String                        @id
  titleCardId          String                        @map("topicId")
  recordType           TitleCardResearchRecordType
  recordStatus         TitleCardResearchRecordStatus @default(draft)
  versionNo            Int                           @default(1)
  parentRecordId       String?
  supersededByRecordId String?
  sourceRecordIds      Json                          @default("[]")
  lineage              Json                          @default("{}")
  summary              String
  confidence           Decimal                       @db.Decimal(4, 3)
  blockingIssues       Json                          @default("[]")
  missingInformation   Json                          @default("[]")
  nextActions          Json                          @default("[]")
  evidenceRefs         Json                          @default("[]")
  payload              Json
  createdBy            String                        @default("hybrid")
  createdAt            DateTime                      @db.Timestamptz(6)
  updatedAt            DateTime                      @db.Timestamptz(6)
  deletedAt            DateTime?                     @db.Timestamptz(6)
  parent               TitleCardResearchRecord?      @relation("TitleCardResearchRecordParent", fields: [parentRecordId], references: [id], onDelete: SetNull)
  children             TitleCardResearchRecord[]     @relation("TitleCardResearchRecordParent")
  supersededBy         TitleCardResearchRecord?      @relation("TitleCardResearchRecordSuperseded", fields: [supersededByRecordId], references: [id], onDelete: SetNull)
  supersedes           TitleCardResearchRecord[]     @relation("TitleCardResearchRecordSuperseded")
  researchQuestions    TitleCardResearchQuestion[]
  needReviews          TitleCardNeedReview[]
  valueAssessments     TitleCardValueAssessment[]
  packages             TitleCardPackage[]

  @@index([titleCardId, recordType, recordStatus])
  @@index([titleCardId, updatedAt(sort: Desc)])
  @@map("TopicResearchRecord")
}

model TitleCard {
  id              String                       @id
  workingTitle    String
  brief           String
  status          TitleCardStatus              @default(draft)
  basketUpdatedAt DateTime                     @db.Timestamptz(6)
  createdAt       DateTime                     @db.Timestamptz(6)
  updatedAt       DateTime                     @db.Timestamptz(6)
  evidenceBasket  TitleCardEvidenceSelection[]

  @@index([status, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model TitleCardEvidenceSelection {
  titleCardId  String
  literatureId String
  selectedAt   DateTime         @db.Timestamptz(6)
  titleCard    TitleCard        @relation(fields: [titleCardId], references: [id], onDelete: Cascade)
  literature   LiteratureRecord @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@id([titleCardId, literatureId])
  @@index([literatureId])
  @@index([titleCardId, selectedAt(sort: Desc)])
}

model TitleCardResearchQuestion {
  id                          String                          @id
  titleCardId                 String                          @map("topicId")
  researchRecordId            String                          @unique
  mainQuestion                String
  subQuestions                Json                            @default("[]")
  researchSlice               String
  contributionHypothesis      TitleCardContributionHypothesis
  sourceNeedReviewIds         Json                            @default("[]")
  sourceLiteratureEvidenceIds Json                            @default("[]") @map("sourceEvidenceReviewIds")
  createdAt                   DateTime                        @db.Timestamptz(6)
  updatedAt                   DateTime                        @db.Timestamptz(6)
  researchRecord              TitleCardResearchRecord         @relation(fields: [researchRecordId], references: [id], onDelete: Cascade)
  valueAssessments            TitleCardValueAssessment[]
  packages                    TitleCardPackage[]
  promotionDecisions          TitleCardPromotionDecision[]

  @@index([titleCardId, updatedAt(sort: Desc)])
  @@map("TopicQuestion")
}

model TitleCardNeedReview {
  id                   String                  @id
  titleCardId          String                  @map("topicId")
  researchRecordId     String                  @unique
  needStatement        String
  whoNeedsIt           String
  scenario             String
  boundary             String?
  unmetNeedCategory    String
  falsificationVerdict String
  significanceScore    Int
  measurabilityScore   Int
  feasibilitySignal    String
  validatedNeed        Boolean
  evidenceReviewRefs   Json                    @default("[]")
  literatureIds        Json                    @default("[]")
  createdAt            DateTime                @db.Timestamptz(6)
  updatedAt            DateTime                @db.Timestamptz(6)
  researchRecord       TitleCardResearchRecord @relation(fields: [researchRecordId], references: [id], onDelete: Cascade)

  @@index([titleCardId, updatedAt(sort: Desc)])
  @@index([titleCardId, validatedNeed])
  @@map("TopicNeedReview")
}

model TitleCardValueAssessment {
  id                      String                       @id
  titleCardId             String                       @map("topicId")
  researchQuestionId      String                       @map("questionId")
  researchRecordId        String                       @unique
  strongestClaimIfSuccess String
  fallbackClaimIfSuccess  String?
  hardGates               Json
  scoredDimensions        Json
  riskPenalty             Json
  reviewerObjections      Json                         @default("[]")
  ceilingCase             String
  baseCase                String
  floorCase               String
  verdict                 TitleCardValueVerdict
  totalScore              Decimal                      @db.Decimal(5, 2)
  createdAt               DateTime                     @db.Timestamptz(6)
  updatedAt               DateTime                     @db.Timestamptz(6)
  researchRecord          TitleCardResearchRecord      @relation(fields: [researchRecordId], references: [id], onDelete: Cascade)
  researchQuestion        TitleCardResearchQuestion    @relation(fields: [researchQuestionId], references: [id], onDelete: Cascade)
  packages                TitleCardPackage[]
  promotionDecisions      TitleCardPromotionDecision[]

  @@index([titleCardId, updatedAt(sort: Desc)])
  @@index([researchQuestionId, updatedAt(sort: Desc)])
  @@map("TopicValueAssessment")
}

model TitleCardPackage {
  id                            String                       @id
  titleCardId                   String                       @map("topicId")
  researchQuestionId            String                       @map("questionId")
  valueAssessmentId             String
  researchRecordId              String                       @unique
  titleCandidates               Json                         @default("[]")
  researchBackground            String
  contributionSummary           String
  candidateMethods              Json                         @default("[]")
  evaluationPlan                String
  keyRisks                      Json                         @default("[]")
  selectedLiteratureEvidenceIds Json                         @default("[]")
  createdAt                     DateTime                     @db.Timestamptz(6)
  updatedAt                     DateTime                     @db.Timestamptz(6)
  researchRecord                TitleCardResearchRecord      @relation(fields: [researchRecordId], references: [id], onDelete: Cascade)
  researchQuestion              TitleCardResearchQuestion    @relation(fields: [researchQuestionId], references: [id], onDelete: Cascade)
  valueAssessment               TitleCardValueAssessment     @relation(fields: [valueAssessmentId], references: [id], onDelete: Cascade)
  promotionDecisions            TitleCardPromotionDecision[]

  @@index([titleCardId, updatedAt(sort: Desc)])
  @@map("TopicPackage")
}

model TitleCardPromotionDecision {
  id                 String                         @id
  titleCardId        String                         @map("topicId")
  researchQuestionId String                         @map("questionId")
  valueAssessmentId  String
  packageId          String?
  decision           TitleCardPromotionDecisionType
  reasonSummary      String
  targetPaperTitle   String?
  promotedPaperId    String?
  loopbackTarget     String?
  createdBy          String
  createdAt          DateTime                       @db.Timestamptz(6)
  updatedAt          DateTime                       @db.Timestamptz(6)
  researchQuestion   TitleCardResearchQuestion      @relation(fields: [researchQuestionId], references: [id], onDelete: Cascade)
  valueAssessment    TitleCardValueAssessment       @relation(fields: [valueAssessmentId], references: [id], onDelete: Cascade)
  package            TitleCardPackage?              @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([titleCardId, createdAt(sort: Desc)])
  @@map("TopicPromotionDecision")
}

model ResearchArgumentWorkspace {
  id                    String                             @id
  titleCardId           String
  workspaceStatus       String
  activeBranchId        String?
  currentStage          String
  sourceTraceRefs       Json                               @default("[]")
  reportPointers        Json                               @default("[]")
  paperId               String?
  syncEligibility       String
  authorizationMetadata Json?
  gitWeakMappingRefs    Json                               @default("[]")
  auditRef              String?
  createdAt             DateTime                           @db.Timestamptz(6)
  updatedAt             DateTime                           @db.Timestamptz(6)
  branches              ResearchArgumentBranch[]
  graphObjects          ResearchArgumentGraphObject[]
  stateSnapshots        ResearchArgumentStateSnapshot[]
  decisionRecords       ResearchArgumentDecisionRecord[]
  lessonRecords         ResearchArgumentLessonRecord[]
  reportProjections     ResearchArgumentReportProjection[]

  @@index([titleCardId])
  @@index([workspaceStatus, updatedAt(sort: Desc)])
}

model ResearchArgumentBranch {
  id                String                             @id
  workspaceId       String
  branchName        String
  branchStatus      String
  parentBranchId    String?
  hypothesisSummary String?
  branchReason      String?
  decisionRefs      Json                               @default("[]")
  createdAt         DateTime                           @db.Timestamptz(6)
  updatedAt         DateTime                           @db.Timestamptz(6)
  workspace         ResearchArgumentWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  graphObjects      ResearchArgumentGraphObject[]
  stateSnapshots    ResearchArgumentStateSnapshot[]
  decisionRecords   ResearchArgumentDecisionRecord[]
  lessonRecords     ResearchArgumentLessonRecord[]
  reportProjections ResearchArgumentReportProjection[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, branchStatus])
}

model ResearchArgumentGraphObject {
  objectId    String
  workspaceId String
  branchId    String
  objectKind  String
  payload     Json
  createdAt   DateTime                  @db.Timestamptz(6)
  updatedAt   DateTime                  @db.Timestamptz(6)
  workspace   ResearchArgumentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch      ResearchArgumentBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([workspaceId, branchId, objectId])
  @@index([workspaceId, branchId, objectKind])
  @@index([branchId, updatedAt(sort: Desc)])
}

model ResearchArgumentStateSnapshot {
  id          String                    @id
  workspaceId String
  branchId    String
  stage       String
  dimensions  Json
  globalFlags Json
  derived     Json
  version     Int
  createdAt   DateTime                  @db.Timestamptz(6)
  updatedAt   DateTime                  @db.Timestamptz(6)
  workspace   ResearchArgumentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch      ResearchArgumentBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([workspaceId, branchId, updatedAt(sort: Desc)])
}

model ResearchArgumentDecisionRecord {
  id               String                    @id
  workspaceId      String
  branchId         String
  action           String
  reason           String
  actor            String
  humanConfirmed   Boolean
  confirmationNote String?
  linkedObjectIds  Json                      @default("[]")
  auditRef         String?
  createdAt        DateTime                  @db.Timestamptz(6)
  workspace        ResearchArgumentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch           ResearchArgumentBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([workspaceId, branchId, createdAt(sort: Desc)])
}

model ResearchArgumentLessonRecord {
  id                String                    @id
  workspaceId       String
  branchId          String
  lessonType        String
  summary           String
  originDecisionId  String?
  originRunIds      Json                      @default("[]")
  applicabilityTags Json                      @default("[]")
  reliability       Float?
  createdAt         DateTime                  @db.Timestamptz(6)
  updatedAt         DateTime                  @db.Timestamptz(6)
  workspace         ResearchArgumentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch            ResearchArgumentBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([workspaceId, branchId, updatedAt(sort: Desc)])
}

model ResearchArgumentReportProjection {
  id              String                    @id
  workspaceId     String
  branchId        String
  reportKind      String
  summary         String
  objectPointers  Json                      @default("[]")
  sourceTraceRefs Json                      @default("[]")
  reportPointers  Json                      @default("[]")
  createdAt       DateTime                  @db.Timestamptz(6)
  updatedAt       DateTime                  @db.Timestamptz(6)
  workspace       ResearchArgumentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch          ResearchArgumentBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, branchId, reportKind])
  @@index([workspaceId, updatedAt(sort: Desc)])
}
